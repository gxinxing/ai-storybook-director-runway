# Runway API Key (Required)
# Get your key from: https://app.runwayml.com/
RUNWAY_API_KEY=your_runway_api_key_here

# LLM Provider Configuration
# Options: deepseek, openai, claude
LLM_PROVIDER=deepseek

# DeepSeek API Key (Required if LLM_PROVIDER=deepseek)
# Get your key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key (Optional, backup)
# Get your key from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Optional, backup)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
